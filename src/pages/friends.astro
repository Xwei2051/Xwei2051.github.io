---
import { getEntry, render } from "astro:content";
import Comment from "@components/comment/index.astro";
import FriendCard from "@components/features/friends/FriendCard.astro";
import { PageHeader } from "@components/features/page-header";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

import { siteConfig } from "../config";
import { getShuffledFriendsList } from "../data/friends";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

export const prerender = true;

if (!siteConfig.featurePages.friends) {
	return Astro.redirect("/404/");
}

const friendsPost = await getEntry("spec", "friends");

if (!friendsPost) {
	throw new Error("friends page content not found");
}

const { Content } = await render(friendsPost);
const friendsList = getShuffledFriendsList();
const allTags = Array.from(new Set(friendsList.flatMap((item) => item.tags)));
---

<MainGridLayout
	title={i18n(I18nKey.friends)}
	description={i18n(I18nKey.friends)}
>
	<script is:inline>
		window.isFriendsPage = true;
	</script>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<div
		class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-6 sm:px-9 py-6 relative w-full">
			<PageHeader
				title={i18n(I18nKey.friends)}
				subtitle={i18n(I18nKey.friendsSubtitle)}
			/>

			<!-- 搜索和筛选栏 -->
			<div class="mb-6 space-y-3">
				<!-- 搜索框 -->
				<div class="w-full">
					<div class="relative">
						<input
							type="text"
							id="friend-search"
							placeholder={i18n(I18nKey.friendsSearchPlaceholder)}
							class="friend-search-field w-full px-4 py-3 pl-11 text-black/90 dark:text-white/90 transition-all duration-200"
						/>
						<svg
							class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-black/40 dark:text-white/40"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
							></path>
						</svg>
					</div>
				</div>

				<!-- 标签筛选 -->
				<div class="filter-container flex flex-wrap gap-2">
					<button class="filter-tag active" data-tag="all">
						<Icon name="material-symbols:apps" />
						{i18n(I18nKey.friendsFilterAll)}
					</button>
					{
						allTags.map((tag) => (
							<button class="filter-tag" data-tag={tag}>
								{tag}
							</button>
						))
					}
				</div>
			</div>

			<!-- 友链卡片网格 -->
			<div
				id="friends-grid"
				class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6 mb-6"
			>
				{friendsList.map((item) => <FriendCard friend={item} />)}
			</div>

			<!-- 无结果提示 -->
			<div id="no-results" class="hidden text-center py-12">
				<svg
					class="w-16 h-16 mx-auto mb-4 text-black/20 dark:text-white/20"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
					></path>
				</svg>
				<p class="text-black/50 dark:text-white/50 text-lg">
					{i18n(I18nKey.friendsNoResults)}
				</p>
			</div>

			<!-- 说明文档 -->
			<Markdown class="mt-8 prose dark:prose-invert max-w-none">
				<Content />
			</Markdown>

			<!-- 隐藏元素用于传递 i18n 文本到全局脚本 -->
			<div id="friends-copy-success-text" style="display: none;">
				{i18n(I18nKey.friendsCopySuccess)}
			</div>
		</div>
	</div>

	<!-- 引用全局脚本 -->
	<script is:inline src="/js/friends-page-handler.js"></script>

	<div class="mt-4">
		<Comment path="/friends/" />
	</div>
</MainGridLayout>

<style>
	/* 搜索框焦点效果 */
	#friend-search:focus {
		outline: none;
		box-shadow:
			0 0 0 1px color-mix(in oklab, var(--primary) 42%, transparent),
			0 0 22px oklch(0.72 0.16 var(--hue) / 0.16);
	}

	.friend-search-field {
		border: 1px solid color-mix(in oklab, var(--primary) 18%, var(--line-divider));
		border-radius: 0.9rem;
		background:
			linear-gradient(
				135deg,
				color-mix(in oklab, var(--btn-regular-bg) 92%, var(--primary) 8%),
				color-mix(in oklab, var(--btn-regular-bg) 98%, black 2%)
			);
	}

	.friend-search-field::placeholder {
		color: color-mix(in oklab, var(--regular-text) 60%, transparent);
	}

	/* 标签筛选按钮样式 */
	.filter-container {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.filter-tag {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.48rem 0.95rem;
		border: 1px solid color-mix(in oklab, var(--primary) 15%, var(--line-divider));
		border-radius: var(--radius-large);
		background: color-mix(in oklab, var(--btn-regular-bg) 88%, var(--primary) 7%);
		color: color-mix(in oklab, var(--primary) 58%, var(--btn-content));
		font-size: 0.875rem;
		font-weight: 500;
		cursor: pointer;
		transition: all 0.2s ease;
		white-space: nowrap;
	}

	.filter-tag :global(svg) {
		width: 1rem;
		height: 1rem;
	}

	.filter-tag:hover:not(.active) {
		background: color-mix(in oklab, var(--primary) 12%, var(--btn-regular-bg));
		border-color: color-mix(in oklab, var(--primary) 38%, transparent);
		transform: translateY(-1px);
	}

	.filter-tag.active {
		background:
			linear-gradient(
				135deg,
				oklch(0.72 0.15 var(--hue)),
				oklch(0.68 0.14 calc(var(--hue) + 70))
			);
		color: white;
		border-color: transparent;
		box-shadow: 0 8px 18px oklch(0.66 0.15 var(--hue) / 0.18);
	}

	.filter-tag.active:hover {
		color: white !important;
		transform: translateY(-1px);
	}

	:global(:root.dark) .friend-search-field {
		background:
			linear-gradient(
				135deg,
				color-mix(in oklab, var(--btn-regular-bg) 90%, white 4%),
				color-mix(in oklab, var(--btn-regular-bg) 98%, black 2%)
			);
	}
</style>
