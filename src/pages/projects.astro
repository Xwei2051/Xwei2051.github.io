---
import { FilterTabs } from "@components/atoms/filter-tabs";
import { PageHeader } from "@components/features/page-header";
import { ProjectCard } from "@components/features/projects";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

import { siteConfig } from "../config";
import { UNCATEGORIZED } from "../constants/constants";
import { getProjectStats, projectsData } from "../data/projects";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

if (!siteConfig.featurePages.projects) {
	return Astro.redirect("/404/");
}

const categories = [
	...new Set(projectsData.map((project) => project.category)),
];

const getCategoryText = (category: string) => {
	switch (category) {
		case "web":
			return i18n(I18nKey.projectsWeb);
		case "mobile":
			return i18n(I18nKey.projectsMobile);
		case "desktop":
			return i18n(I18nKey.projectsDesktop);
		case "other":
			return i18n(I18nKey.projectsOther);
		case UNCATEGORIZED:
			return i18n(I18nKey.uncategorized);
		default:
			return category;
	}
};

const filterTabs = [
	{
		value: "all",
		label: i18n(I18nKey.friendsFilterAll),
		icon: "material-symbols:apps",
	},
	...categories.map((category) => ({
		value: category,
		label: getCategoryText(category),
	})),
];

const title = i18n(I18nKey.projects);
const subtitle = i18n(I18nKey.projectsSubtitle);
const projectStats = getProjectStats();
---

<MainGridLayout title={title} description={subtitle}>
	<script>
		import("../scripts/right-sidebar-layout.js");
		import { loadIconify } from "../utils/icon-loader";

		loadIconify().catch((error) => {
			console.error("Failed to load Iconify:", error);
		});
	</script>

	<script is:inline src="/js/filter-tabs-handler.js"></script>

	<div
		class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-6 sm:px-9 py-6 relative w-full">
			<PageHeader title={title} subtitle={subtitle} />

			<div class="projects-meta mb-8">
				<span>
					<Icon name="material-symbols:dashboard-rounded" />
					<strong>{projectStats.total}</strong> 个项目
				</span>
				<span>
					<Icon name="material-symbols:construction-rounded" />
					<strong>{projectStats.byStatus.inProgress}</strong> 个进行中
				</span>
				<span>
					<Icon name="material-symbols:verified-rounded" />
					<strong>{projectStats.byStatus.completed}</strong> 个完成
				</span>
			</div>

			<div class="mb-8">
				<FilterTabs tabs={filterTabs} dataAttr="category" class="projects-filter" />
			</div>

			<div
				id="projects-grid"
				class="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch"
			>
				{
					projectsData.map((project) => (
						<ProjectCard project={project} maxTechStack={4} />
					))
				}
			</div>

			<div id="no-results" class="hidden text-center py-16">
				<Icon
					name="material-symbols:search-off-rounded"
					class="text-6xl text-black/15 dark:text-white/15 mb-4"
				/>
				<p class="text-black/40 dark:text-white/40 text-lg">
					No matching projects
				</p>
			</div>
		</div>
	</div>
</MainGridLayout>

<style>
	.projects-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.55rem;
		margin-top: -0.75rem;
	}

	.projects-meta span {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		min-height: 2rem;
		padding: 0.35rem 0.72rem;
		border: 1px solid color-mix(in oklab, var(--primary) 16%, var(--line-divider));
		border-radius: 999px;
		background: color-mix(in oklab, var(--btn-regular-bg) 90%, var(--primary) 6%);
		color: color-mix(in oklab, var(--regular-text) 82%, var(--primary));
		font-size: 0.84rem;
		font-weight: 560;
		line-height: 1;
	}

	.projects-meta :global(svg) {
		width: 1rem;
		height: 1rem;
		color: oklch(0.74 0.15 var(--hue));
	}

	.projects-meta strong {
		color: var(--deep-text);
		font-weight: 800;
	}

	:global(:root.dark) .projects-meta span {
		border-color: oklch(0.72 0.13 var(--hue) / 0.2);
		background: oklch(0.62 0.12 var(--hue) / 0.1);
		color: rgba(255, 255, 255, 0.68);
	}

	:global(:root.dark) .projects-meta strong {
		color: rgba(255, 255, 255, 0.9);
	}

	:global(.projects-filter) {
		gap: 0.65rem;
	}

	:global(.projects-filter .filter-tabs-item) {
		border: 1px solid color-mix(in oklab, var(--primary) 15%, var(--line-divider)) !important;
		border-radius: var(--radius-large) !important;
		background: color-mix(in oklab, var(--btn-regular-bg) 88%, var(--primary) 7%) !important;
		color: color-mix(in oklab, var(--primary) 58%, var(--btn-content)) !important;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
	}

	:global(.projects-filter .filter-tabs-item:hover:not(.active)) {
		border-color: color-mix(in oklab, var(--primary) 38%, transparent) !important;
		background: color-mix(in oklab, var(--primary) 12%, var(--btn-regular-bg)) !important;
		transform: translateY(-1px);
	}

	:global(.projects-filter .filter-tabs-item.active) {
		border-color: transparent !important;
		background:
			linear-gradient(
				135deg,
				oklch(0.72 0.15 var(--hue)),
				oklch(0.68 0.14 calc(var(--hue) + 70))
			) !important;
		color: white !important;
		box-shadow: 0 8px 18px oklch(0.66 0.15 var(--hue) / 0.18) !important;
		transform: translateY(-1px);
	}

	:global(.projects-filter .filter-tabs-item.active iconify-icon),
	:global(.projects-filter .filter-tabs-item.active .filter-tabs-count) {
		color: white !important;
		opacity: 0.9;
	}

	:global(.projects-filter .filter-tabs-count) {
		opacity: 0.72;
	}

	:global(:root.dark .projects-filter .filter-tabs-item) {
		border-color: oklch(0.72 0.13 var(--hue) / 0.24) !important;
		background: oklch(0.62 0.12 var(--hue) / 0.12) !important;
		color: rgba(255, 255, 255, 0.74) !important;
	}

	:global(:root.dark .projects-filter .filter-tabs-item:hover:not(.active)) {
		border-color: oklch(0.74 0.13 var(--hue) / 0.42) !important;
		background: oklch(0.62 0.12 var(--hue) / 0.18) !important;
	}

	:global(:root.dark .projects-filter .filter-tabs-item.active) {
		border-color: transparent !important;
		background:
			linear-gradient(
				135deg,
				oklch(0.72 0.15 var(--hue)),
				oklch(0.68 0.14 calc(var(--hue) + 70))
			) !important;
		color: white !important;
	}

	@media (width < 640px) {
		.projects-meta {
			margin-top: -0.5rem;
		}
	}
</style>
