---
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";

interface Props {
	friend: {
		title: string;
		siteurl: string;
		imgurl: string;
		desc: string;
		tags: string[];
	};
}

const { friend } = Astro.props;
const hostname = new URL(friend.siteurl).hostname;
---

<div
	class="friend-card group relative overflow-hidden rounded-xl transition-all duration-300"
	data-title={friend.title.toLowerCase()}
	data-desc={friend.desc.toLowerCase()}
	data-tags={friend.tags.join(",")}
>
	<div class="relative z-10 flex h-full flex-col p-6">
		<!-- 头像和标题区 -->
		<div class="mb-4 flex items-start gap-4">
			<div
				class="friend-logo h-16 w-16 shrink-0 overflow-hidden rounded-xl transition-all duration-300"
			>
				<img
					src={friend.imgurl}
					alt={friend.title}
					class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-300"
					loading="lazy"
				/>
			</div>

			<div class="flex-1 min-w-0">
				<h3
					class="mb-1 truncate text-xl font-bold text-black/90 transition-colors duration-200 group-hover:text-(--primary) dark:text-white/90"
				>
					{friend.title}
				</h3>
				<a
					href={friend.siteurl}
					target="_blank"
					rel="noopener noreferrer"
					class="block truncate text-xs text-black/50 transition-colors duration-200 hover:text-(--primary) dark:text-white/50"
				>
					{hostname}
				</a>
			</div>
		</div>

		<!-- 描述 -->
		<p
			class="mb-4 min-h-10 text-sm leading-7 text-black/60 line-clamp-2 dark:text-white/60"
		>
			{friend.desc}
		</p>

		<!-- 标签 -->
		<div class="mb-5 flex flex-wrap gap-2">
			{
				friend.tags.map((tag) => (
					<span class="friend-tag px-2 py-1 text-xs font-medium">
						{tag}
					</span>
				))
			}
		</div>

		<!-- 操作按钮 -->
		<div class="mt-auto flex gap-2">
			<a
				href={friend.siteurl}
				target="_blank"
				rel="noopener noreferrer"
				class="friend-link flex flex-1 items-center justify-center gap-2 px-4 py-2 text-sm font-medium transition-all duration-200 active:scale-95"
			>
				<svg
					class="w-4 h-4"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
					></path>
				</svg>
				{i18n(I18nKey.friendsVisit)}
			</a>
			<button
				class="copy-link-btn friend-copy px-3 py-2 text-black/70 transition-all duration-200 active:scale-95 dark:text-white/70"
				data-url={friend.siteurl}
				title={i18n(I18nKey.friendsCopyLink)}
			>
				<svg
					class="w-4 h-4"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
					></path>
				</svg>
			</button>
		</div>
	</div>

	<!-- 悬停装饰效果 -->
	<div
		class="friend-card-glow pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
	>
	</div>
</div>

<style>
	.friend-card {
		animation: fadeInUp 0.5s ease-out forwards;
		opacity: 0;
		border: 1px solid color-mix(in oklab, var(--primary) 16%, var(--line-divider));
		background:
			linear-gradient(
				145deg,
				color-mix(in oklab, var(--card-bg) 96%, var(--primary) 4%),
				color-mix(in oklab, var(--card-bg) 98%, black 2%)
			);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
	}

	.friend-card:hover {
		border-color: color-mix(in oklab, var(--primary) 42%, var(--line-divider));
		transform: translateY(-2px);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.05),
			0 18px 38px rgba(0, 0, 0, 0.14);
	}

	.friend-logo {
		background: color-mix(in oklab, var(--btn-regular-bg) 88%, var(--primary) 12%);
		box-shadow:
			0 0 0 1px color-mix(in oklab, var(--primary) 16%, transparent),
			0 10px 24px rgba(0, 0, 0, 0.12);
	}

	.friend-card:hover .friend-logo {
		box-shadow:
			0 0 0 1px color-mix(in oklab, var(--primary) 36%, transparent),
			0 12px 26px rgba(0, 0, 0, 0.16),
			0 0 18px oklch(0.7 0.16 var(--hue) / 0.24);
	}

	.friend-tag {
		border: 1px solid color-mix(in oklab, var(--primary) 18%, transparent);
		border-radius: 0.5rem;
		background: color-mix(in oklab, var(--primary) 9%, transparent);
		color: color-mix(in oklab, var(--primary) 74%, var(--regular-text));
	}

	.friend-link,
	.friend-copy {
		border: 1px solid color-mix(in oklab, var(--primary) 18%, var(--line-divider));
		border-radius: 0.7rem;
		background: color-mix(in oklab, var(--btn-regular-bg) 86%, var(--primary) 8%);
		color: color-mix(in oklab, var(--primary) 72%, var(--deep-text));
	}

	.friend-link:hover,
	.friend-copy:hover {
		border-color: color-mix(in oklab, var(--primary) 42%, transparent);
		background: color-mix(in oklab, var(--primary) 16%, var(--btn-regular-bg));
	}

	.friend-card-glow {
		background:
			radial-gradient(
				circle at 18% 12%,
				oklch(0.72 0.16 var(--hue) / 0.12),
				transparent 38%
			),
			linear-gradient(135deg, oklch(0.7 0.16 var(--hue) / 0.06), transparent 58%);
	}

	:global(:root.dark) .friend-card {
		background:
			linear-gradient(
				145deg,
				color-mix(in oklab, var(--card-bg) 94%, white 3%),
				color-mix(in oklab, var(--card-bg) 98%, black 2%)
			);
	}

	:global(:root.dark) .friend-link,
	:global(:root.dark) .friend-copy {
		color: rgba(255, 255, 255, 0.78);
	}

	:global(:root.dark) .friend-tag {
		border-color: oklch(0.72 0.13 var(--hue) / 0.34);
		background: oklch(0.62 0.12 var(--hue) / 0.18);
		color: rgba(255, 255, 255, 0.78);
		text-shadow: 0 1px 1px rgba(0, 0, 0, 0.28);
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.friend-card:nth-child(1) {
		animation-delay: 0.05s;
	}
	.friend-card:nth-child(2) {
		animation-delay: 0.1s;
	}
	.friend-card:nth-child(3) {
		animation-delay: 0.15s;
	}
	.friend-card:nth-child(4) {
		animation-delay: 0.2s;
	}
	.friend-card:nth-child(5) {
		animation-delay: 0.25s;
	}
	.friend-card:nth-child(6) {
		animation-delay: 0.3s;
	}
</style>
