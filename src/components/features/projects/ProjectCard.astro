---
import { Icon } from "astro-icon/components";

import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import type { ProjectCardProps } from "./types";

const { project, maxTechStack = 4 } = Astro.props as ProjectCardProps;

const hasImage = !!project.image;
const showImageArea = project.showImage !== false && hasImage;
const hasVisitUrl = !!project.visitUrl;
const hasSourceCode = !!project.sourceCode;

const getStatusText = (status: string) => {
	switch (status) {
		case "completed":
			return i18n(I18nKey.projectsCompleted);
		case "in-progress":
			return i18n(I18nKey.projectsInProgress);
		case "planned":
			return i18n(I18nKey.projectsPlanned);
		default:
			return status;
	}
};
---

<div
	class="project-card group relative h-full overflow-hidden rounded-xl transition-all duration-300"
	data-category={project.category}
>
	{
		showImageArea && (
			<div class="project-cover relative aspect-video overflow-hidden">
				{hasImage ? (
					<img
						src={project.image!}
						alt={project.title}
						class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
						loading="lazy"
					/>
				) : (
					<div class="w-full h-full flex items-center justify-center">
						<span class="text-4xl font-bold text-(--primary)/15 select-none tracking-wide">
							{project.title}
						</span>
					</div>
				)}
				<div class="absolute inset-0 bg-linear-to-t from-black/24 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
				{project.featured && (
					<div class="absolute top-3 right-3">
						<Icon
							name="material-symbols:star-rounded"
							class="text-(--primary) text-xl drop-shadow-sm"
							style="filter: drop-shadow(0 1px 2px rgba(0,0,0,0.2));"
						/>
					</div>
				)}
			</div>
		)
	}

	<div class="flex h-full flex-col p-5">
		<div class="mb-3 flex items-start justify-between gap-3">
			<h3
				class="min-w-0 text-lg font-bold text-black/90 transition-colors duration-200 group-hover:text-(--primary) dark:text-white/90"
			>
				{project.title}
			</h3>
			<span
				class="project-status shrink-0 px-2 py-0.5 text-xs font-medium"
			>
				{getStatusText(project.status)}
			</span>
		</div>

		<p
			class="text-sm text-black/60 dark:text-white/60 mb-4 line-clamp-2 min-h-10"
		>
			{project.description}
		</p>

		{
			project.techStack && project.techStack.length > 0 && (
				<div class="flex flex-wrap gap-2 mb-4">
					{project.techStack.slice(0, maxTechStack).map((tech) => (
						<span class="project-tech px-2 py-1 text-xs font-medium">
							{tech}
						</span>
					))}
					{project.techStack.length > maxTechStack && (
						<span class="project-tech-more px-2 py-1 text-xs font-medium">
							+{project.techStack.length - maxTechStack}
						</span>
					)}
				</div>
			)
		}

		<div class="mt-auto min-h-10">
			{
				(hasVisitUrl || hasSourceCode) && (
					<div class="flex gap-2">
					{hasVisitUrl && (
						<a
							href={project.visitUrl!}
							target="_blank"
							rel="noopener noreferrer"
							class="project-action flex flex-1 items-center justify-center gap-2 px-4 py-2 text-sm font-medium"
						>
							<Icon
								name="material-symbols:open-in-new"
								class="text-base w-4 h-4"
							/>
							{i18n(I18nKey.projectsVisit)}
						</a>
					)}
					{hasSourceCode && (
						<a
							href={project.sourceCode!}
							target="_blank"
							rel="noopener noreferrer"
							class="project-action flex items-center justify-center gap-2 px-4 py-2 text-sm font-medium"
							style={hasVisitUrl ? "" : "flex: 1;"}
						>
							<Icon name="mdi:github" class="text-base w-4 h-4" />
							{!hasVisitUrl && "GitHub"}
						</a>
					)}
				</div>
				)
			}
		</div>
	</div>

	<div
		class="project-glow pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
	>
	</div>
</div>

<style>
	.project-card {
		animation: fadeInUp 0.5s ease-out forwards;
		opacity: 0;
		border: 1px solid color-mix(in oklab, var(--primary) 15%, var(--line-divider));
		background:
			linear-gradient(
				145deg,
				color-mix(in oklab, var(--card-bg) 96%, var(--primary) 4%),
				color-mix(in oklab, var(--card-bg) 98%, black 2%)
			);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
	}

	.project-card:hover {
		border-color: color-mix(in oklab, var(--primary) 40%, var(--line-divider));
		transform: translateY(-2px);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.05),
			0 18px 38px rgba(0, 0, 0, 0.14);
	}

	.project-card.filtered-out {
		display: none;
	}

	.project-cover {
		background:
			radial-gradient(
				circle at 18% 18%,
				oklch(0.72 0.16 var(--hue) / 0.18),
				transparent 38%
			),
			linear-gradient(
				135deg,
				color-mix(in oklab, var(--btn-regular-bg) 84%, var(--primary) 12%),
				color-mix(in oklab, var(--btn-regular-bg) 96%, black 4%)
			);
	}

	.project-status,
	.project-tech,
	.project-tech-more {
		border: 1px solid color-mix(in oklab, var(--primary) 18%, transparent);
		border-radius: 0.5rem;
		background: color-mix(in oklab, var(--primary) 9%, transparent);
		color: color-mix(in oklab, var(--primary) 74%, var(--regular-text));
	}

	.project-tech-more {
		border-color: var(--line-divider);
		background: var(--btn-regular-bg);
		color: color-mix(in oklab, var(--regular-text) 78%, transparent);
	}

	.project-action {
		border: 1px solid color-mix(in oklab, var(--primary) 18%, var(--line-divider));
		border-radius: 0.7rem;
		background: color-mix(in oklab, var(--btn-regular-bg) 86%, var(--primary) 8%);
		color: color-mix(in oklab, var(--primary) 72%, var(--deep-text));
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			transform 0.2s ease;
	}

	.project-action:hover {
		border-color: color-mix(in oklab, var(--primary) 42%, transparent);
		background: color-mix(in oklab, var(--primary) 16%, var(--btn-regular-bg));
	}

	.project-action:active {
		transform: scale(0.97);
	}

	.project-glow {
		background:
			radial-gradient(
				circle at 18% 12%,
				oklch(0.72 0.16 var(--hue) / 0.12),
				transparent 38%
			),
			linear-gradient(135deg, oklch(0.7 0.16 var(--hue) / 0.06), transparent 58%);
	}

	:global(:root.dark) .project-card {
		background:
			linear-gradient(
				145deg,
				color-mix(in oklab, var(--card-bg) 94%, white 3%),
				color-mix(in oklab, var(--card-bg) 98%, black 2%)
			);
	}

	:global(:root.dark) .project-action {
		color: rgba(255, 255, 255, 0.78);
	}

	:global(:root.dark) .project-status,
	:global(:root.dark) .project-tech {
		border-color: oklch(0.72 0.13 var(--hue) / 0.34);
		background: oklch(0.62 0.12 var(--hue) / 0.18);
		color: rgba(255, 255, 255, 0.78);
		text-shadow: 0 1px 1px rgba(0, 0, 0, 0.28);
	}

	:global(:root.dark) .project-tech-more {
		color: rgba(255, 255, 255, 0.62);
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.project-card:nth-child(1) {
		animation-delay: 0.05s;
	}
	.project-card:nth-child(2) {
		animation-delay: 0.1s;
	}
	.project-card:nth-child(3) {
		animation-delay: 0.15s;
	}
	.project-card:nth-child(4) {
		animation-delay: 0.2s;
	}
	.project-card:nth-child(5) {
		animation-delay: 0.25s;
	}
	.project-card:nth-child(6) {
		animation-delay: 0.3s;
	}
	.project-card:nth-child(7) {
		animation-delay: 0.35s;
	}
	.project-card:nth-child(8) {
		animation-delay: 0.4s;
	}

	.line-clamp-2 {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
